<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<Template isFullResponsive="true">
    <Name>SVS</Name>
    <Author>SolidConcept</Author>
    <URL>https://www.solidconcept.de</URL>
    <Parent>NOVA</Parent>
    <Preview>preview.png</Preview>
    <Version>1.2.1</Version>
    <MinShopVersion>5.2.0</MinShopVersion>
    <Description>Dieses Template ist ein individuell für "SVS" angepasstes NOVA Child-Template.</Description>
    <Settings>
        <Section Name="Theme" Key="theme">
            <Setting Description="Theme" Key="theme_default" Type="select" Value="svs" override="true">
                <Option Value="svs">SVS</Option>
            </Setting>
        </Section>

        <Section Name="Individuelle-Einstellungen" Key="sonstige">
            <Setting Description="Pive-ID" Key="prive" Type="text" Value="" />
            <Setting Description="Analytics/Tagmanager-ID" Key="google" Type="text" Value="" />
        </Section>
    </Settings>
    <Minify>
        <CSS Name="svs.css">
            <File Path="themes/svs/svs.css"/>
            <File Path="themes/svs/custom.css"/>
        </CSS>
    </Minify>
    <Boxes>
        <Container Position="left" Available="1" />
        <Container Position="right" Available="0" />
        <Container Position="top" Available="0" />
        <Container Position="bottom" Available="1" />
    </Boxes>
</Template>
